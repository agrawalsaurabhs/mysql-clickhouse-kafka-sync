# MySQL Configuration for Change Data Capture (CDC)
# Optimized for Debezium connector

[mysqld]
# Basic settings
bind-address = 127.0.0.1
mysqlx-bind-address = 127.0.0.1

# Server ID (required for replication)
server-id = 1

# Binary logging settings (required for CDC)
log-bin = mysql-bin
binlog_format = ROW
binlog_row_image = FULL
binlog_expire_logs_seconds = 864000  # 10 days

# GTID settings (recommended for better replication)
gtid_mode = OFF
enforce_gtid_consistency = OFF
log_replica_updates = OFF

# Performance settings
binlog_cache_size = 32768
max_binlog_cache_size = 2147483648
max_binlog_size = 1073741824

# Character set
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# InnoDB settings
default_storage_engine = InnoDB
innodb_file_per_table = ON

# SQL mode
sql_mode = STRICT_TRANS_TABLES,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

[mysql]
default-character-set = utf8mb4

[client]
default-character-set = utf8mb4

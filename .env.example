# CDC Pipeline Environment Configuration
# Copy this file to .env and update with your actual passwords

# Executable Paths (adjust based on your system)
CLICKHOUSE_BIN=clickhouse
BREW_BIN=brew
HOMEBREW_PREFIX=/opt/homebrew

# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=password
MYSQL_USER=debezium
MYSQL_PASSWORD=debezium_password

# ClickHouse Configuration  
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse_password

# Kafka Configuration
KAFKA_HOST=localhost
KAFKA_PORT=9092
ZOOKEEPER_HOST=localhost
ZOOKEEPER_PORT=2181
KAFKA_PASSWORD=kafka_password

# Debezium Configuration
DEBEZIUM_REST_PORT=8083
DEBEZIUM_PASSWORD=debezium_password
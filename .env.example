# CDC Pipeline Environment Configuration
# Copy this file to .env and update with your actual values

# -- Homebrew ------------------------------------------------------------------
# /opt/homebrew on Apple Silicon, /usr/local on Intel Macs
HOMEBREW_PREFIX=/opt/homebrew

# -- MySQL ---------------------------------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=inventory
MYSQL_ROOT_PASSWORD=password
MYSQL_USER=debezium
MYSQL_PASSWORD=debezium_password

# -- ClickHouse ----------------------------------------------------------------
# Binary is downloaded by clickhouse-setup/install.sh into that folder
CLICKHOUSE_BIN=clickhouse-setup/clickhouse
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DB=cdc_sync
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# -- Kafka (KRaft mode -- no Zookeeper) ----------------------------------------
KAFKA_HOST=localhost
KAFKA_PORT=9092

# -- Debezium ------------------------------------------------------------------
DEBEZIUM_VERSION=2.4.0.Final
DEBEZIUM_REST_PORT=8083